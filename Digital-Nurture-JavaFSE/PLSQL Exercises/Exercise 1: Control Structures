03_Scenario1_SeniorCitizenBenefit.sql
SET SERVEROUTPUT ON;

DECLARE

    CURSOR customer_cursor IS
        SELECT CustomerID, Name, DOB
        FROM Customers;

    v_customer_id Customers.CustomerID%TYPE;
    v_customer_name Customers.Name%TYPE;
    v_dob Customers.DOB%TYPE;
    v_age NUMBER;

BEGIN

    OPEN customer_cursor;

    LOOP

        FETCH customer_cursor
        INTO v_customer_id, v_customer_name, v_dob;

        EXIT WHEN customer_cursor%NOTFOUND;

        v_age := TRUNC(MONTHS_BETWEEN(SYSDATE,v_dob)/12);

        IF v_age >= 60 THEN

            UPDATE Loans
            SET InterestRate = InterestRate - 1
            WHERE CustomerID = v_customer_id;

            DBMS_OUTPUT.PUT_LINE(
                'Interest rate reduced for '
                || v_customer_name
            );

        END IF;

    END LOOP;

    CLOSE customer_cursor;

    COMMIT;

    DBMS_OUTPUT.PUT_LINE('Senior citizen benefit applied.');

END;


04_Scenario2_VIPIdentification.sql
SET SERVEROUTPUT ON;

DECLARE

    CURSOR vip_cursor IS
        SELECT CustomerID, Name, Balance
        FROM Customers;

    v_id Customers.CustomerID%TYPE;
    v_name Customers.Name%TYPE;
    v_balance Customers.Balance%TYPE;

BEGIN

    OPEN vip_cursor;

    LOOP

        FETCH vip_cursor
        INTO v_id, v_name, v_balance;

        EXIT WHEN vip_cursor%NOTFOUND;

        IF v_balance > 10000 THEN

            UPDATE Customers
            SET IsVIP='TRUE'
            WHERE CustomerID=v_id;

            DBMS_OUTPUT.PUT_LINE(
                v_name || ' marked as VIP.'
            );

        ELSE

            UPDATE Customers
            SET IsVIP='FALSE'
            WHERE CustomerID=v_id;

        END IF;

    END LOOP;

    CLOSE vip_cursor;

    COMMIT;

    DBMS_OUTPUT.PUT_LINE('VIP status verification completed.');

END;

05_Scenario3_LoanRepaymentReminder.sql
SET SERVEROUTPUT ON;

DECLARE

    CURSOR reminder_cursor IS
        SELECT
            c.Name,
            l.LoanID,
            l.EndDate
        FROM Customers c
        JOIN Loans l
        ON c.CustomerID = l.CustomerID
        WHERE l.EndDate BETWEEN SYSDATE AND SYSDATE + 30;

    v_name Customers.Name%TYPE;
    v_loan_id Loans.LoanID%TYPE;
    v_due_date Loans.EndDate%TYPE;

BEGIN

    OPEN reminder_cursor;

    LOOP

        FETCH reminder_cursor
        INTO v_name, v_loan_id, v_due_date;

        EXIT WHEN reminder_cursor%NOTFOUND;

        DBMS_OUTPUT.PUT_LINE(
            'Reminder -> Customer: '
            || v_name
            || ', Loan ID: '
            || v_loan_id
            || ', Due Date: '
            || TO_CHAR(v_due_date,'DD-MON-YYYY')
        );

    END LOOP;

    CLOSE reminder_cursor;

    DBMS_OUTPUT.PUT_LINE('Reminder process completed.');

END;
